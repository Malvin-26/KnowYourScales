{
  "name": "know-your-scales",
  "version": "1.0.0",
  "private": true,
  "description": "Interactive music theory learning platform",
  "engines": {
    "node": ">=22.5.0"
  },
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "npm run dev --prefix server",
    "dev:client": "npm run dev --prefix client",
    "build:client": "npm run build --workspace=know-your-scales-client",
    "build:pages": "cross-env GITHUB_PAGES=true npm run build:client",
    "build": "npm run build:client && npm run build --prefix server",
    "start": "npm run start --prefix server",
    "db:seed": "npm run db:seed --prefix server",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3"
  }
}
